      <link name="start_marker">
        <pose>-7 -4 0.006 0 0 0</pose>
        <visual name="visual">
          <geometry><box><size>1.0 0.6 0.012</size></box></geometry>
          <material>
            <ambient>0.0 0.8 0.25 1</ambient>
