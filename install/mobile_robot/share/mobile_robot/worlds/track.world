      <link name="goal_marker">
        <pose>7 4 0.006 0 0 0</pose>
        <visual name="visual">
          <geometry><box><size>1.0 0.6 0.012</size></box></geometry>
          <material>
            <ambient>0.1 0.35 1.0 1</ambient>
            <diffuse>0.1 0.35 1.0 1</diffuse>
