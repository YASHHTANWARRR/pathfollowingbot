        </collision>
        <visual name="visual">
          <geometry><box><size>12 0.25 1.0</size></box></geometry>
          <material>
            <ambient>0.12 0.12 0.10 1</ambient>
            <diffuse>0.23 0.22 0.18 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="inner_east_wall">
        <pose>6 0 0.5 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.25 4.25 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.25 4.25 1.0</size></box></geometry>
          <material>
            <ambient>0.12 0.12 0.10 1</ambient>
            <diffuse>0.23 0.22 0.18 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="inner_west_wall">
        <pose>-6 0 0.5 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.25 4.25 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.25 4.25 1.0</size></box></geometry>
          <material>
            <ambient>0.12 0.12 0.10 1</ambient>
            <diffuse>0.23 0.22 0.18 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="bottom_centerline">
        <pose>0 -4 0.01 0 0 0</pose>
        <visual name="visual">
          <geometry><box><size>14 0.08 0.02</size></box></geometry>
          <material>
            <ambient>1.0 0.75 0.05 1</ambient>
            <diffuse>1.0 0.75 0.05 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="top_centerline">
        <pose>0 4 0.01 0 0 0</pose>
        <visual name="visual">
