      <link name="east_centerline">
        <pose>8 0 0.01 0 0 1.570796</pose>
        <visual name="visual">
          <geometry><box><size>8 0.08 0.02</size></box></geometry>
          <material>
            <ambient>1.0 0.75 0.05 1</ambient>
            <diffuse>1.0 0.75 0.05 1</diffuse>
